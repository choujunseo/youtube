VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_AD_GROUP_ID=your-toss-ad-group-id
# 업로드 제출 시 리워드 광고 그룹 (없으면 VITE_AD_GROUP_ID)
# VITE_AD_GROUP_UPLOAD=
# 부스트 전용 (없으면 VITE_AD_GROUP_ID)
# VITE_AD_GROUP_BOOST=
VITE_PROMOTION_CODE=your-toss-promotion-code
VITE_IS_MOCK=true

# 앱인토스 콘솔 > 공유 리워드에 등록한 moduleId (비우면 My의 공유 버튼에서 안내 토스트)
# VITE_CONTACTS_VIRAL_MODULE_ID=
VITE_FEED_BOOST_WEIGHT_DEFAULT=1.5
VITE_FEED_BOOST_WEIGHT_FEVER=1.4
VITE_FEED_BOOST_CONSECUTIVE_CAP=3
VITE_FEED_BOOST_JITTER_MIN=0.92
VITE_FEED_BOOST_JITTER_RANGE=0.16
VITE_BOOST_DURATION_MINUTES=120

# 실시간 랭킹: KST 피버 창 밖에서도 탭·페이지 허용 (프로덕션 빌드 테스트 시만. 기본은 npm run dev에서 이미 열림)
# VITE_RANKING_ALWAYS_OPEN=true

# 점검 화면(MaintenancePage) 미리보기 — true면 항상 점검 UI (배포 번들에는 넣지 말 것)
# VITE_MAINTENANCE_PREVIEW=true

# 주간 점검 시간(KST, 월요일 기준) - [시작, 종료) 범위
# VITE_MAINTENANCE_START_HOUR_KST=1
# VITE_MAINTENANCE_END_HOUR_KST=6

# 랭킹 UI 미리보기 — 1등 카드를 "내가 투표 + 내 당첨확률" 상태로 강제 표시
# VITE_RANKING_TOP_VOTED_PREVIEW=true

# My 탭 미리보기 — 지난 주 정산 결과/내가 투표한 아이디어/알림을 샘플 데이터로 표시
# VITE_MY_TABS_PREVIEW=true

# Supabase Dashboard → Edge Functions → Secrets (배포 서버 전용, Vite .env에 넣지 마세요)
# TOSS_CLIENT_ID=
# TOSS_CLIENT_SECRET=
# TOSS_MTLS_CERT_PEM=
# TOSS_MTLS_KEY_PEM=
# TOSS_PROMOTION_CODE=           # 실지급 프로모션 코드 (S2S)
# TOSS_PROMOTION_EXECUTE_URL=    # 기본값: apps-in-toss promotion execute endpoint
# PAYOUT_DRY_RUN=false           # true면 실지급 API 호출 없이 성공 처리(개발/리허설용)
