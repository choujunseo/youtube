# Vite 클라이언트 번들에만 포함 (VITE_).
# Edge Function 시크릿: supabase/.edge-secrets.source.env.example → supabase/.edge-secrets.source.env 후 npm run secrets:edge

# 현재 클라우드 프로젝트 (ref: doycnnibictugtnobebs). 다른 프로젝트면 URL/키만 교체.
VITE_SUPABASE_URL=https://doycnnibictugtnobebs.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# 앱인토스 인앱 광고 adGroupId — 출시 전에는 공식 테스트 ID 사용 권장
# https://developers-apps-in-toss.toss.im/ads/develop.md (리워드·전면 테스트 ID)
# 운영 콘솔 그룹 ID로 바꿀 때 다섯 변수 모두 교체하면 됨.
VITE_AD_GROUP_UPLOAD=ait-ad-test-rewarded-id
VITE_AD_GROUP_BOOST=ait-ad-test-rewarded-id
VITE_AD_GROUP_VOTE_TICKET=ait-ad-test-rewarded-id
VITE_AD_GROUP_HALL_OF_FAME_GATE=ait-ad-test-interstitial-id
# 배너 광고 - 피드형(텍스트 강조) : ait-ad-test-banner-id
VITE_AD_GROUP_FEED_TOP_BANNER=ait-ad-test-banner-id

# 토스 프로모션 코드(콘솔 ID) — 클라 SDK 연동 시에만 사용. 실제 S2S 지급은 Edge 시크릿 TOSS_PROMOTION_CODE_CREATOR|VOTER|FIRST_VOTE
VITE_PROMOTION_CODE_CREATOR=
VITE_PROMOTION_CODE_VOTER=
VITE_PROMOTION_CODE_FIRST_VOTE=

# 토스 앱 공유 — 앱 이름(intoss://<name>)과 OG 이미지 절대 URL
# 배포 후 실제 CDN 경로로 교체할 것 (https:// 필수)
VITE_TOSS_APP_NAME=idea-league
VITE_OG_SHARE_IMAGE_URL=https://your-project-ref.supabase.co/storage/v1/object/public/og/share-og.png

# UI 목 데이터만 켤 때 true. true면 웰컴「다음」이 토스 로그인 없이 /feed 로 감(실계정 테스트 시 false 권장).
# VITE_IS_MOCK=true
# VITE_USE_MOCK_APP_LOGIN=true
# VITE_CONTACTS_VIRAL_MODULE_ID=
VITE_FEED_BOOST_WEIGHT_DEFAULT=1.5
VITE_FEED_BOOST_WEIGHT_FEVER=1.4
VITE_FEED_BOOST_CONSECUTIVE_CAP=3
VITE_FEED_BOOST_JITTER_MIN=0.92
VITE_FEED_BOOST_JITTER_RANGE=0.16
VITE_BOOST_DURATION_MINUTES=120
# VITE_MY_TABS_PREVIEW=true
# VITE_RANKING_TOP_VOTED_PREVIEW=true
