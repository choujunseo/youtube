# Copy to supabase/.edge-secrets.source.env (gitignored) and run: npm run secrets:edge
# Never commit real keys.
#
# `supabase secrets set` 은 이름이 SUPABASE_ 로 시작하는 항목을 건너뜁니다(호스팅 Edge 에서 자동 주입).
# 로컬 `supabase functions serve` 는 아래 SUPABASE_* 가 있어야 동작합니다.

# 프로젝트 doycnnibictugtnobebs 기준. Dashboard → Settings → API 에서 anon / service_role 복사.
SUPABASE_URL=https://doycnnibictugtnobebs.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Toss Apps-in-Toss partner API (auth-token-exchange) — 개발자센터에서 발급
TOSS_CLIENT_ID=
TOSS_CLI_SECRET=

# mTLS — 콘솔 mTLS 인증서 탭에서 발급한 client cert + private key (PEM).
# https://developers-apps-in-toss.toss.im/development/integration-process.md
# 한 줄로 넣기 어렵면 cert/key 파일을 base64 인코딩해 *_B64 로만 설정해도 됨.
# TOSS_MTLS_CERT_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# TOSS_MTLS_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# TOSS_MTLS_CERT_B64=
# TOSS_MTLS_KEY_B64=
# (선택) 커스텀 CA 체인
# TOSS_MTLS_CA_PEM=
# 프로덕션에서 mTLS 없으면 503 — 로컬만 평문 허용 시 false 유지
# TOSS_PARTNER_REQUIRE_MTLS=true

# toss-disconnect 웹훅 Basic Auth — 토스 콘솔과 동일한 값으로 설정
TOSS_WEBHOOK_USER=idea-league-webhook
TOSS_WEBHOOK_PASSWORD=generate-a-long-random-secret

# payout-worker 수동/크론 호출 보호용 (임의 긴 문자열)
PAYOUT_WORKER_SECRET=

# payout-worker — 토스 프로모션 S2S (콘솔 코드 ID). reason 별로 세 개 모두 필요. 미설정 시 해당 건 failed.
# TOSS_PROMOTION_CODE_CREATOR=
# TOSS_PROMOTION_CODE_VOTER=
# TOSS_PROMOTION_CODE_FIRST_VOTE=

# 스마트 발송(기능성 알림) — 콘솔 템플릿 세트 코드. 고정 문구면 API는 빈 context 로 발송.
# https://developers-apps-in-toss.toss.im/smart-message/develop.md
# 콘솔 템플릿 세트 코드와 동일 문자열로 맞출 것 (고정 문구 템플릿이면 변수 불필요).
TOSS_SMART_TEMPLATE_GRADUATION_CREATOR=idea_league_graduation_creator
TOSS_SMART_TEMPLATE_GRADUATION_VOTER=idea_league_graduation_voter
# 스마트 발송 API만 끄기(프로모션 지급은 유지). 미설정·빈 값이면 해당 역할 템플릿은 발송 안 함.
# TOSS_SMART_MESSAGE_SKIP=true

# (현재 미사용) develop.md §5 복호화 키 — auth-token-exchange 는 실명을 display_name 에 넣지 않음(닉네임만 앱에서 설정).
# TOSS_USER_INFO_AES_KEY_BASE64=
# TOSS_USER_INFO_AAD=TOSS
